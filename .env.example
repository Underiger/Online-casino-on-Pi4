# ============================================================
# Virtual Casino Sandbox — 環境變數範本
# 複製為 .env 後填入實際值；機密值可用 scripts/gen-secrets.sh 產生
#   cp .env.example .env
#   bash scripts/gen-secrets.sh
# .env 已列入 .gitignore，嚴禁提交
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
# 日誌等級：fatal/error/warn/info/debug/trace
LOG_LEVEL=info
# node:cluster fork 數（1–4；Pi 4 建議 2）
WORKERS=2
SOCKET_MAX_CONNECTIONS=200

# --- PostgreSQL（docker-compose dev 服務使用）---
POSTGRES_USER=casino
POSTGRES_PASSWORD=change_me
POSTGRES_DB=casino_dev
POSTGRES_PORT=5432

# --- Prisma 連線字串 ---
# 開發（local PostgreSQL，由 docker-compose 啟動）；user/password/db 須與上方 POSTGRES_* 一致：
DATABASE_URL=postgresql://casino:change_me@localhost:5432/casino_dev?schema=public
#
# 開發替代方案（SQLite，免 Docker）。Prisma 不支援 provider 動態切換，
# SQLite 模式使用獨立 schema（backend/prisma/schema.sqlite.prisma）：
#   DATABASE_URL=file:./dev.sqlite        ← 路徑相對於 backend/prisma/
#   cd backend
#   npm run prisma:push:sqlite            ← 建表（物化視圖等 PG 專屬物件跳過）
#   npm run prisma:generate:sqlite        ← 生成 SQLite 版 client
#   npm run prisma:seed                   ← 種子（自動偵測 provider）
# 切回 PostgreSQL：npx prisma generate（讀主 schema）
# DATABASE_URL=file:./dev.sqlite

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- 認證 / 安全（由 scripts/gen-secrets.sh 產生）---
# JWT HS256 簽章金鑰（≥ 64 hex chars）
JWT_SECRET=change_me
# Access Token 存活時間
JWT_ACCESS_TTL=15m
# Refresh Token 存活天數（旋轉式）
REFRESH_TOKEN_TTL_DAYS=7
# AES-256-GCM 金鑰（恰 64 hex chars = 32 bytes；TOTP secret 加密用）
AES_256_GCM_KEY=change_me

# --- Admin 初始帳號（M02 seed 使用）---
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change_me

# --- 異常通知（可選；M24 使用）---
ALERT_WEBHOOK_URL=
